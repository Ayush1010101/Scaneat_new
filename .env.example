# Database
DATABASE_URL=mysql://user:password@localhost:3306/scaneat

# JWT Secret for session cookies
JWT_SECRET=your-jwt-secret-key-at-least-32-chars-long

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Google Gemini API (for food analysis)
GEMINI_API_KEY=your-google-gemini-api-key

# AWS S3 Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=scaneat-uploads

# OpenAI Whisper (optional, for voice transcription)
OPENAI_API_KEY=your-openai-api-key

# Google Maps API (optional, for restaurant finder)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Admin user email (first user with this email gets admin role)
ADMIN_EMAIL=your-admin@email.com

# Server
PORT=3000
NODE_ENV=development
